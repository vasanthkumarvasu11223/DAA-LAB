#include <iostream>
using namespace std;

void maxHeapify(int a[], int n, int i) {
    int largest = i;
    int left = 2*i + 1;
    int right = 2*i + 2;

    if (left < n && a[left] > a[largest])
        largest = left;

    if (right < n && a[right] > a[largest])
        largest = right;

    if (largest != i) {
        swap(a[i], a[largest]);
        maxHeapify(a, n, largest);
    }
}

void buildMaxHeap(int a[], int n) {
    for (int i = n/2 - 1; i >= 0; i--)
        maxHeapify(a, n, i);
}

int main() {
    int a[] = {9, 4, 7, 1, 3};
    int n = 5;

    buildMaxHeap(a, n);

    cout << "Max Heap: ";
    for(int i=0;i<n;i++)
        cout << a[i] << " ";
}
